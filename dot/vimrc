" Set viewoptions to only save folds and cursor position
set viewoptions=folds,cursor

" Save view automatically when leaving a buffer or writing the file
autocmd BufWinLeave ?* mkview
autocmd BufWritePost ?* mkview

" Load view automatically when entering a buffer
autocmd BufWinEnter ?* silent! loadview

" Start with no swap file for new buffers
set noswapfile

" Enable swap file only after the first modification
autocmd BufWritePre,BufReadPost * setlocal noswapfile
autocmd InsertEnter,TextYankPost * setlocal swapfile

"autocmd BufNewFile,BufReadPost ~/MEGA/vimwiki/* setlocal noswapfile
