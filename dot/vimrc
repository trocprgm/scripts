nnoremap ? :nohlsearch<CR>

function! LeftRecover()
    wincmd l
    diffget
    RecoverPluginFinish
    write
endfunction

function! RightRecover()
    wincmd l
    diffput
    RecoverPluginFinish
    write
endfunction

command Boing call Boing()
command Fin :RecoverPluginFinish
command Left call LeftRecover()
command Right call RightRecover()
command Rec :RecoverPluginHelp
command Dippy :!{echo "Test"}

