fuzzy() {
  local dir
    if [ -z "$1" ]; then
        dir=$(fd -H -E .git --type f . "$(pwd)" | fzf --preview 'bat -n --color=always --line-range :500 {}' ) || return
      # echo "$dir"
      realpath "$dir"
    elif [ -n "$1" ]; then
      dir=$(fd -H -E .git --type f . "$1/" | fzf --preview 'bat -n --color=always --line-range :500 {}' ) || return
      # echo "$dir"
      realpath "$dir"
    fi
}

alias fuzzc="fuzzy "$1/" | xclip -selection c"

