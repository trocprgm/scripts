clippy() {
    rm "$CLIPTEMP"
    touch "$CLIPTEMP"
    if [ "$1" == "tmux" ]; then
        # echo "<h1>***TMUX***</h1>" >> "$CLIPTEMP"
        echo "###   TMUX   ###" >> "$CLIPTEMP"
        # echo -e "Buffer 0: $(tmux show-buffer -b buffer0)\n" >> "$CLIPTEMP"
        # echo -e "Buffer 1: $(tmux show-buffer -b buffer1)\n" >> "$CLIPTEMP"
        # echo -e "Buffer 2: $(tmux show-buffer -b buffer2)\n" >> "$CLIPTEMP"
        # echo -e "Buffer 3: $(tmux show-buffer -b buffer3)\n" >> "$CLIPTEMP"
        # echo -e "Buffer 4: $(tmux show-buffer -b buffer4)\n" >> "$CLIPTEMP"
        echo "$(tmux list-buffers)" | awk 'BEGIN { FS="bytes: " } { print $2 }' >> "$CLIPTEMP"
    elif [ "$1" == "bak" ]; then
    echo "###   VIM BACKUP   ###" >> "$CLIPTEMP"
    echo -e "$(vimbackup)" >> "$CLIPTEMP"
    elif [ "$1" == "swp" ]; then
    echo "###   VIM SWAP   ###" >> "$CLIPTEMP"
    echo -e "$(vimswap)" >> "$CLIPTEMP"
    elif [ "$1" == "vim" ]; then
    echo "###   VIM SWAP   ###" >> "$CLIPTEMP"
    echo -e "$(vimswap)" >> "$CLIPTEMP"
    echo "###   VIM BACKUP   ###" >> "$CLIPTEMP"
    echo -e "$(vimbackup)" >> "$CLIPTEMP"
    else
    for sel in Germany Poland Clipboard; do
      out=$(xclip -selection "$sel" -o 2>/dev/null || true)
      echo -e "\n###   $sel   ###" >> "$CLIPTEMP"
      [[ -n "$out" ]] && echo "$out" >> "$CLIPTEMP" || echo "<empty>" >> "$CLIPTEMP"
    done
    fi
    bat --style=plain --language=md "$CLIPTEMP"
    # bat -f "$CLIPTEMP"
}

